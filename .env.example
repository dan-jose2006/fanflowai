# FanFlow AI — Environment Variables Reference
# ──────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT:  Copy this file to .env.local  (git-ignored)
# VERCEL PRODUCTION:  Set these in Project → Settings → Environment Variables
# ──────────────────────────────────────────────────────────────────────────────

# ── Frontend ──────────────────────────────────────────────────────────────────
# Backend API base URL.
#   Local dev  →  http://localhost:8000
#   Vercel     →  leave EMPTY (the frontend hits /api which is proxied on the same domain)
VITE_API_URL=http://localhost:8000

# ── Backend (set in Vercel project env vars, NOT committed here) ───────────────
# Groq LLaMA-3 API key — required for AI responses
# GROQ_API_KEY=gsk_...

# Optional: API-Sports key for live match scores (fetched server-side)
# Leave blank to use static historical match data (clearly labelled in the UI)
# VITE_API_SPORTS_KEY=

# Allowed CORS origins (comma-separated) — defaults to localhost for local dev
# Production example: ALLOWED_ORIGINS=https://fanflowai.vercel.app
# ALLOWED_ORIGINS=https://fanflowai.vercel.app
