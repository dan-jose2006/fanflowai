# FanFlow AI — Frontend Environment Variables
# Copy this file to .env.local for local development.
# NEVER commit .env.local to version control.

# Backend API base URL — set to your deployed backend in production
VITE_API_URL=http://localhost:8000

# Optional: API-Sports key for live match scores (fetched server-side via backend)
# Leave blank to use historical match data (clearly labelled in the UI)
VITE_API_SPORTS_KEY=
