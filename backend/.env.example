# FanFlow AI — Backend Environment Variables
# Copy this file to .env (local) or set these in your hosting provider.
# NEVER commit .env files with real keys to version control.

# ── Groq AI (required for AI assistant & summaries) ──────────────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── API-Sports (optional — for live match data) ───────────────────────────────
# Get your key at: https://api-sports.io
# Without this key, the match endpoint returns verified static data from the
# 2022 FIFA World Cup Final (clearly labelled as simulated/historical).
API_SPORTS_KEY=your_api_sports_key_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
